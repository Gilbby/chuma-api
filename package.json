{
  "name": "chuma-backend",
  "version": "1.0.0",
  "description": "Backend API for Chuma — carrier-agnostic village banking app for Zambia",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seed.js",
    "cron:fee-lock": "node src/jobs/feeLockReminders.job.js",
    "cron:penalty": "node src/jobs/penaltyDetection.job.js",
    "cron:reconcile": "node src/jobs/statusReconciliation.job.js",
    "test:webhook-sig": "node scripts/test-pawapay-signature.mjs",
    "check:deposit": "node scripts/check-deposit.mjs",
    "verify:retry-payout": "node scripts/verify-retry-payout.mjs",
    "verify:failed-payout": "node scripts/verify-failed-payout.mjs",
    "verify:shareout": "node scripts/verify-shareout-success.mjs",
    "verify:settlement-race": "node scripts/verify-settlement-race.mjs",
    "verify:record-violation": "node scripts/verify-record-violation.mjs",
    "verify:validate-first": "node scripts/verify-validate-before-initiate.mjs",
    "verify:group-report": "node scripts/verify-group-report.mjs"
  },
  "keywords": [
    "village-banking",
    "chuma",
    "zambia",
    "fintech"
