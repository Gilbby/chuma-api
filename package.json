  "author": "Chuma",
  "license": "UNLICENSED",
  "dependencies": {
    "africastalking": "^0.7.0",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "http-message-signatures": "^1.0.6",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.5.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "overrides": {
    "axios": "^1.18.1",
    "joi": "^18.2.3",
    "lodash": "^4.18.1"
  }
